                        "on-surface-variant": "#4e4639",
                        "on-primary": "#ffffff",
                        "secondary-fixed": "#ffdad3",
                        "on-tertiary-fixed-variant": "#474744",
                        "on-secondary-container": "#7a564f",
                        "primary": "#775a19",
                        "surface-container-high": "#f0e7df",
                        "on-secondary-fixed": "#2e140f",
