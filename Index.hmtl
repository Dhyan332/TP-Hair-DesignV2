<img alt="Salon detail" class="w-full h-80 object-cover rounded-lg mt-12" data-alt="Close up of professional hair stylist hands carefully applying color to a client's hair in a brightly lit salon" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDEMqOGtmVj8VOhcN0SfN8qE4E_-jwg1HtmXnVCIVuNc34MJmsOgImzYj_2H_Fbw1Dohv64qMG1gAKgEu2kCeo2JFL8ZHQttZtMkz__z-nL8tC7g5O1IY5owydbZZYukxkH5HUWVjywQe7Ssyn7ufEFtaSWnElqdArE9-iUBQMBvZjfJ1wve8H4SKzoF0-vcKWkJ01rx_R99hLk--3fkUDoYtuz1Uny_G8Jn_hPKhM8pLNVYNKaEjPz6uCK9YgmCT-OSRzdpLC3teK-"/>
